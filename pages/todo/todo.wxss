page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8;
  overflow: hidden;
}

.add-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  flex-shrink: 0;
}

.add-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #333;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background-color: #4a90d9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.add-btn-hover {
  opacity: 0.7;
}

.add-btn-text {
  font-size: 40rpx;
  color: #fff;
  line-height: 1;
}

.timeline-scroll {
  flex: 1;
  padding: 24rpx 0;
}

.empty-timeline {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.empty-text {
  font-size: 28rpx;
  color: #bbb;
}

.timeline {
  padding: 0 32rpx 0 80rpx;
}

.timeline-group {
  position: relative;
}

.timeline-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #999;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
}

.timeline-items {
  position: relative;
  padding-left: 24rpx;
  border-left: 2rpx solid #e0e0e0;
}

.timeline-item {
  position: relative;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
}

.timeline-item.is-last {
  margin-bottom: 0;
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -35rpx;
  top: 8rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 10rpx;
  background-color: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.timeline-dot.dot-completed {
  background-color: #b8d4b8;
}

.dot-inner {
  width: 10rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background-color: #fff;
}

.dot-inner.dot-inner-completed {
  background-color: #6bbf6b;
}

.timeline-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.timeline-card.card-completed {
  opacity: 0.55;
}

.card-hover {
  opacity: 0.7;
}

.todo-content {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.todo-content.content-done {
  text-decoration: line-through;
  color: #bbb;
}

.todo-time {
  font-size: 22rpx;
  color: #ccc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.timeline-end {
  height: 32rpx;
}
