page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.about-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background-color: #4a90d9;
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.app-desc {
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.info-card {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 48rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.info-label {
  font-size: 30rpx;
  color: #333;
}

.info-value {
  font-size: 28rpx;
  color: #999;
}
