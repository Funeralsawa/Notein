page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.auth-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.auth-card {
  width: 100%;
  max-width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow: 0 2rpx 20rpx rgba(0, 0, 0, 0.06);
}

.auth-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 48rpx;
}

.auth-field {
  margin-bottom: 28rpx;
}

.auth-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.auth-input {
  height: 88rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #333;
}

.auth-btn {
  height: 92rpx;
  background-color: #4a90d9;
  border-radius: 46rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 36rpx;
}

.auth-btn-disabled {
  opacity: 0.6;
}

.auth-btn-hover {
  opacity: 0.8;
}

.auth-btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.auth-switch {
  margin-top: 32rpx;
  text-align: center;
}

.auth-switch-text {
  font-size: 26rpx;
  color: #4a90d9;
}

.link-hover {
  opacity: 0.6;
}
