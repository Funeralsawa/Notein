page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
  overflow: hidden;
}

.search-bar {
  padding: 16rpx 24rpx;
  background-color: #fff;
  flex-shrink: 0;
}

.search-input {
  height: 64rpx;
  background-color: #f0f0f0;
  border-radius: 32rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
}

.category-bar {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background-color: #fff;
  flex-shrink: 0;
}

.category-tag {
  font-size: 24rpx;
  color: #888;
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  background-color: #f5f5f5;
  transition: all 0.2s;
}

.category-tag.category-active {
  color: #fff;
  background-color: #4a90d9;
}

.tag-hover {
  opacity: 0.7;
}

.card-list {
  flex: 1;
  padding: 16rpx;
}

.masonry {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.masonry-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.note-card {
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.card-hover {
  opacity: 0.85;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-tag {
  display: inline-block;
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.4);
  background-color: rgba(255, 255, 255, 0.5);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
  margin-bottom: 10rpx;
}

.card-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  margin-bottom: 16rpx;
  word-break: break-all;
}

.card-time {
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.list-bottom-spacer {
  height: 160rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: #4a90d9;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.35);
  z-index: 200;
}

.fab-hover {
  opacity: 0.8;
  transform: scale(0.95);
}

.fab-text {
  font-size: 52rpx;
  color: #fff;
  line-height: 1;
  margin-top: -2rpx;
}
