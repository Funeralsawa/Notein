page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.mine-container {
  flex: 1;
  padding: 32rpx;
}

/* 未登录 */
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.avatar-placeholder {
  margin-bottom: 32rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #4a90d9;
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-empty {
  background-color: #ddd;
  color: #999;
}

.login-hint {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.auth-buttons {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.login-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #4a90d9;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn-hover {
  opacity: 0.8;
}

.login-btn-text {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
}

.register-btn {
  width: 200rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.register-btn-hover {
  opacity: 0.7;
}

.register-btn-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

/* 已登录 */
.logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 40rpx;
}

.nickname {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-top: 20rpx;
}

.menu-list {
  width: 100%;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.menu-hover {
  background-color: rgba(0, 0, 0, 0.03);
}

.menu-label {
  font-size: 30rpx;
  color: #333;
}

.menu-value {
  font-size: 24rpx;
  color: #4a90d9;
  margin-left: auto;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.logout-btn {
  width: 400rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background-color: #fff;
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-hover {
  opacity: 0.6;
}

.logout-text {
  font-size: 28rpx;
  color: #999;
}
