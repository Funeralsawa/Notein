<navigation-bar title="我的" back="{{false}}" color="black" background="#FFF"></navigation-bar>

<view class="mine-container">
  <view wx:if="{{isLoggedIn}}" class="logged-in">
    <view class="avatar-area">
      <view class="avatar">{{alias[0] || '?'}}</view>
      <view class="nickname">{{alias}}</view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="onTapSync" hover-class="menu-hover">
        <text class="menu-label">同步到云端</text>
        <text class="menu-value">{{syncing ? '同步中...' : ''}}</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onTapSettings" hover-class="menu-hover">
        <text class="menu-label">设置</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="logout-btn" bindtap="onLogout" hover-class="logout-hover">
      <text class="logout-text">退出登录</text>
    </view>
  </view>

  <view wx:else class="not-logged-in">
    <view class="avatar-placeholder">
      <view class="avatar avatar-empty">?</view>
    </view>
    <text class="login-hint">登录后可同步数据到云端</text>

    <view class="auth-buttons">
      <view class="login-btn" bindtap="onTapLogin" hover-class="login-btn-hover">
        <text class="login-btn-text">登录</text>
      </view>
      <view class="register-btn" bindtap="onTapRegister" hover-class="register-btn-hover">
        <text class="register-btn-text">注册</text>
      </view>
    </view>
  </view>
</view>
