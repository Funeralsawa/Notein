page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.settings-container {
  flex: 1;
  padding: 24rpx 32rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 26rpx;
  color: #aaa;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.card {
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.cell-tap {
  cursor: pointer;
}

.cell-hover {
  background-color: rgba(0, 0, 0, 0.03);
}

.cell-label {
  font-size: 30rpx;
  color: #333;
}

.cell-value {
  font-size: 28rpx;
  color: #999;
}

.cell-label-link {
  font-size: 30rpx;
  color: #4a90d9;
  text-align: center;
  width: 100%;
}

.cell-label-logout {
  font-size: 30rpx;
  color: #e06060;
  text-align: center;
  width: 100%;
}
