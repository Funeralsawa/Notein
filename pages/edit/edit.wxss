page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.edit-scroll {
  flex: 1;
  padding: 32rpx 32rpx 0;
  overflow-y: auto;
}

.title-input {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
  background: transparent;
}

.cat-select {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cat-option {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.45);
  padding: 6rpx 20rpx;
  border-radius: 24rpx;
  background-color: rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.cat-option.cat-option-active {
  color: #fff;
  background-color: rgba(0, 0, 0, 0.45);
}

.cat-hover {
  opacity: 0.7;
}

.content-textarea {
  font-size: 30rpx;
  color: #444;
  line-height: 1.8;
  min-height: 500rpx;
  background: transparent;
  width: 100%;
}

.bottom-spacer {
  height: 32rpx;
}

.color-bar {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 28rpx;
  padding: 24rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.92);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.color-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: border-color 0.2s;
  box-sizing: border-box;
}

.color-circle.active {
  border-color: rgba(0, 0, 0, 0.25);
}

.circle-hover {
  opacity: 0.7;
}

.color-check {
  font-size: 28rpx;
  color: rgba(0, 0, 0, 0.45);
  font-weight: bold;
}
